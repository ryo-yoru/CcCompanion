<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- CcCompanion v0.1: APNs removed. App Group dedicated to cccompanion (separate from main Cc). -->
	<!-- Requires group.starryfield.cccompanion to exist in Apple Developer Portal before fastlane archive. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.starryfield.cccompanion</string>
	</array>
	<!-- APNs remote notifications. Xcode/provisioning must also enable Push Notifications for com.starryfield.cccompanion. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
